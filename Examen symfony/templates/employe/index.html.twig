{% extends 'base.html.twig' %}
{% block title %}Liste des Employes{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Employes</h2>
    <a href="{{ path('employe_create') }}" class="btn btn-primary">+ Ajouter</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="thead-dark">
        <tr>
            <th>Matricule</th>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Département</th>
            <th>Poste</th>
            <th>Contrat</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for employe in employes %}
        {% set contratActif = null %}
        {% for c in employe.contrats %}
            {% if c.actif %}{% set contratActif = c %}{% endif %}
        {% endfor %}
        <tr>
            <td>{{ employe.matricule }}</td>
            <td>{{ employe.nom }}</td>
            <td>{{ employe.prenom }}</td>
            <td>{{ employe.email }}</td>
            <td>{{ employe.departement ? employe.departement.nom : '-' }}</td>
            <td>{{ employe.poste ? employe.poste.intitule : '-' }}</td>
            <td>
                {% if contratActif %}
                    {% if contratActif.typeContrat == 'CDI' %}
                        <span class="badge badge-success">CDI</span>
                    {% elseif contratActif.typeContrat == 'CDD' %}
                        <span class="badge badge-warning">CDD</span>
                    {% else %}
                        <span class="badge badge-info">Stage</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-danger">Sans contrat</span>
                {% endif %}
            </td>
            <td>
                <a href="{{ path('employe_details', {id: employe.id}) }}" class="btn btn-sm btn-info">Voir</a>
                <a href="{{ path('employe_edit',    {id: employe.id}) }}" class="btn btn-sm btn-warning">Editer</a>
                <form action="{{ path('employe_delete', {id: employe.id}) }}" method="post" class="d-inline"
                      onsubmit="return confirm('Supprimer cet employe ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ employe.id) }}">
                    <button class="btn btn-sm btn-danger">Supprimer</button>
                </form>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="8" class="text-center">Aucun employe enregistre.</td></tr>
    {% endfor %}
    </tbody>
</table>

{# Pagination KnpPaginatorBundle #}
<div class="d-flex justify-content-center">
    {{ knp_pagination_render(employes) }}
</div>
{% endblock %}
